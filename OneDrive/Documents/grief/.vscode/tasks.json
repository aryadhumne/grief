{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Flask",
      "type": "shell",
      "command": "python app.py",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build"
    },
    {
      "label": "Start React",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/grief-companion-frontend" },
      "group": "build"
    },
    {
      "label": "Start All",
      "dependsOn": ["Start Flask", "Start React"],
      "dependsOrder": "parallel",
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}